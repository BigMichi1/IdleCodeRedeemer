# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=optional_guild_id_for_testing
DISCORD_CHANNEL_ID=357247482247380994
# Discord user/bot ID that posts promo codes (e.g. the Idle Champions combinations bot).
# When set, only messages from this author are scanned during backfill; all other
# messages are saved to api-logs/discord_other-messages_* for later inspection.
DISCORD_CODE_AUTHOR_ID=

# Database Configuration
DB_PATH=./data/idle.db

# Node environment
NODE_ENV=production
