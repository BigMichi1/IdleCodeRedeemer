{
  "extends": "@tsconfig/bun",
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021"],
    "types": ["bun-types"],
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
